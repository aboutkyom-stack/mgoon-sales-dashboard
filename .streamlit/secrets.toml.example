# Streamlit Cloud Secrets — 템플릿
#
# 사용법
#   Cloud : share.streamlit.io → 앱 → Settings → Secrets에 이 내용을 그대로 붙여넣고 값 채우기
#   로컬  : 이 파일을 .streamlit/secrets.toml 로 복사 후 값 채우기
#           (없어도 .env가 있으면 동작 — 둘 다 있으면 secrets.toml 우선)
#
# 참고
#   - 실제 secrets.toml은 .gitignore 등록되어 GitHub에 올라가지 않음
#   - top-level key는 Streamlit이 환경변수에 자동 매핑 → os.getenv 그대로 동작
#   - [section] 헤더는 환경변수 매핑 X → 본 프로젝트에서는 사용하지 않음

# ── 앱 역할 ──
# owner  : AI 파이프라인 전기능 사용 (개발자/본인)
# partner: 조회 + 이미지 업로드 + 엠군작업대상 토글만 (동료)
APP_ROLE = "partner"

# ── Supabase DB (필수) ──
MY_SUPABASE_URL = "https://eikuzgymjzyjauzeghfg.supabase.co"
MY_SUPABASE_ANON_KEY = "<eikuzgymjzyjauzeghfg 프로젝트의 anon key>"

# ── service_role key (선택) ──
# DDL이나 RLS 우회가 필요한 작업에서만 필요. partner 운영에는 보통 불필요.
# MY_SUPABASE_SERVICE_KEY = "<service_role key>"

# ── AI API (owner 모드에서 Cloud로 파이프라인 돌릴 때만 필요) ──
# partner 모드는 AI 기능 비활성이라 비워둬도 됨.
# ANTHROPIC_API_KEY = "sk-ant-..."
# GEMINI_API_KEY = "..."

# ── 모델 override (선택) ──
# 비워두면 pipeline/models_config.py 기본값 사용. 모델 라인업 변경 시 재배포 없이 갱신 가능.
# CLAUDE_VP_MODELS = "claude-sonnet-4-6,claude-opus-4-7,claude-haiku-4-5-20251001"
# GEMINI_VP_MODELS = "gemini-2.5-flash,gemini-2.5-pro"
# MERGE_MODEL = "claude-sonnet-4-6"
# EXTRACT_MODEL = "claude-sonnet-4-6"

# ── Drive OAuth ──
# Drive 토큰은 Supabase `drive_auth` 테이블에 동기화됨 → secrets에 OAuth 정보 등록 불필요.
# 로컬에서 `python scripts/refresh_oauth_token.py {name}` 실행 시 pickle + DB 자동 갱신.
# Streamlit Cloud는 다음 페이지 로드 시점부터 새 토큰을 DB에서 read하여 사용.
